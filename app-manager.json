{\n  "expo": {\n    "name": "Gestor de Créditos - Manager",\n    "slug": "gestor-creditos-manager",\n    "version": "1.0.0-manager",\n    "orientation": "portrait",\n    "icon": "./assets/icon.png",\n    "userInterfaceStyle": "light",\n    "splash": {\n      "image": "./assets/splash.png",\n      "resizeMode": "contain",\n      "backgroundColor": "#FF9500"\n    },\n    "assetBundlePatterns": ["**/*"],\n    "ios": {\n      "supportsTabletMode": true,\n      "bundleIdentifier": "com.gestorcreditos.manager"\n    },\n    "android": {\n      "adaptiveIcon": {\n        "foregroundImage": "./assets/adaptive-icon.png",\n        "backgroundColor": "#FF9500"\n      },\n      "package": "com.gestorcreditos.manager",\n      "versionCode": 2,\n      "permissions": [\n        "android.permission.INTERNET",\n        "android.permission.CAMERA",\n        "android.permission.READ_EXTERNAL_STORAGE",\n        "android.permission.WRITE_EXTERNAL_STORAGE"\n      ]\n    },\n    "web": {\n      "favicon": "./assets/favicon.png"\n    },\n    "plugins": [\n      [\n        "expo-image-picker",\n        {\n          "photosPermission": "Permite acceso a tus fotos para adjuntar comprobantes",\n          "cameraPermission": "Permite acceso a la cámara para capturar comprobantes"\n        }\n      ]\n    ],\n    "extra": {\n      "eas": {\n        "projectId": "gestor-creditos-manager"\n      },\n      "version_type": "manager",\n      "permissions_level": "medium",\n      "features": [\n        "view_debtors",\n        "edit_payments",\n        "view_reports",\n        "manage_notifications",\n        "export_data"\n      ]\n    }\n  }\n}\n
